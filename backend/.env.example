# MiroFish Backend — Environment Variables
# Copy this file to .env and fill in your actual values

# === Core LLM ===
OPENAI_API_KEY=your_openai_key
# Or any OpenAI-compatible endpoint:
# OPENAI_BASE_URL=https://your-llm-endpoint/v1
# OPENAI_MODEL=gpt-4o

# === Zep Cloud (GraphRAG memory) ===
ZEP_API_KEY=your_zep_cloud_key

# === Seed Agent — web research pipeline ===
# Tavily: web search (https://tavily.com)
TAVILY_API_KEY=your_tavily_key

# Grok / xAI: real-time X/Twitter data (https://x.ai)
GROK_API_KEY=your_xai_key

# Seed Agent tuning (optional — defaults shown)
SEED_MAX_TOKENS=8000
SEED_MAX_SECONDS=90
SEED_MAX_SOURCES=15
